# --- Supabase ---
# Production: https://eoajvifhbmqmoluiokcj.supabase.co
# Staging:    use the widby-staging Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Server-side Supabase key for the Python scoring engine (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# --- DataForSEO ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_BASE_URL=https://api.dataforseo.com

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Mapbox ---
MAPBOX_ACCESS_TOKEN=

# --- FastAPI backend ---
# Production: https://whidby-1.onrender.com
# Staging:    https://whidby-staging.onrender.com
# Local:      http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- App origins ---
# App frontend origin used for auth callback redirects (Vercel URL in production)
NEXT_PUBLIC_APP_FRONTEND_URL=http://localhost:3001
# Consumer app origin — marketing login redirects here after sign-in
NEXT_PUBLIC_CONSUMER_APP_URL=http://localhost:3002

# --- Render FastAPI env ---
# Set ENVIRONMENT=production on prod Render, ENVIRONMENT=staging on staging Render.
# Controls CORS: staging allows *.vercel.app preview origins; production does not.
# ENVIRONMENT=

# Optional: comma-separated extra CORS origins for the FastAPI service
# CORS_EXTRA_ORIGINS=

# --- Vercel ---
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
