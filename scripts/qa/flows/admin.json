{
  "app": "admin",
  "baseUrlEnv": "PLAYWRIGHT_BASE_URL",
  "viewports": [
    { "name": "desktop", "width": 1440, "height": 1000 },
    { "name": "mobile", "width": 390, "height": 844 }
  ],
  "routes": [
    {
      "name": "login",
      "path": "/login",
      "requiresAuth": false,
      "expectedPath": "/login",
      "capture": "page"
    },
    {
      "name": "home",
      "path": "/",
      "requiresAuth": true,
      "expectedPath": "/login",
      "capture": "unauthenticated-redirect"
    },
    {
      "name": "exploration",
      "path": "/exploration",
      "requiresAuth": true,
      "expectedPath": "/login",
      "capture": "unauthenticated-redirect"
    }
  ]
}
