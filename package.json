{
  "name": "nichefinder",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=whidby",
    "dev:app": "turbo dev --filter=nichefinder-app",
    "dev:api": "docker compose up api --build",
    "dev:api:local": "uvicorn src.research_agent.api:app --reload --port 8000"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "turbo": "^2"
  },
  "packageManager": "npm@11.6.0",
  "dependencies": {
    "vercel": "^50.39.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-x64": "^4.60.1"
  }
}
