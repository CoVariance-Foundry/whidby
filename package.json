{
  "name": "nichefinder",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=whidby",
    "dev:app": "turbo dev --filter=widby-app",
    "dev:admin": "turbo dev --filter=widby-admin",
    "dev:api": "docker compose up api --build",
    "dev:api:local": "arch -arm64 uvicorn src.research_agent.api:app --reload --port 8000",
    "env:check": "node scripts/ci/env_manifest_check.mjs",
    "env:plan:vercel": "node scripts/ci/sync_vercel_env.mjs --dry-run",
    "env:plan:github": "node scripts/ci/sync_github_env.mjs",
    "env:plan:supabase": "node scripts/ci/sync_supabase_branch_secrets.mjs",
    "env:plan:preview": "npm run env:plan:vercel -- --environment preview && npm run env:plan:github -- --environment preview && npm run env:plan:supabase -- --environment preview --branch dev",
    "ci:validate-preview-url": "node scripts/ci/validate_preview_url.mjs",
    "ci:wait-check": "node scripts/ci/wait_for_github_check.mjs",
    "ci:find-preview": "node scripts/ci/find_vercel_deployment.mjs",
    "qa:run": "node scripts/qa/run_visual_qa.mjs",
    "qa:agent": "node scripts/qa/agent_review.mjs",
    "qa:post": "node scripts/qa/post_pr_feedback.mjs",
    "qa:visual:app": "playwright test --config=apps/app/playwright.config.ts apps/app/e2e/visual-qa.spec.ts --project=chromium",
    "qa:visual:admin": "playwright test --config=apps/admin/playwright.config.ts apps/admin/e2e/visual-qa.spec.ts --project=chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^27.0.1",
    "turbo": "^2"
  },
  "packageManager": "npm@11.6.0",
  "dependencies": {
    "vercel": "^50.39.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-x64": "^4.60.1"
  }
}
